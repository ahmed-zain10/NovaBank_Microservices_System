###############################################################################
# NovaBank – Local Development Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
###############################################################################

# PostgreSQL
POSTGRES_USER=novabank_admin
POSTGRES_PASSWORD=your_strong_local_password_here

# Per-schema DB passwords (used by docker-compose)
AUTH_DB_PASSWORD=auth_local_pass
ACCOUNTS_DB_PASSWORD=accounts_local_pass
TRANSACTIONS_DB_PASSWORD=transactions_local_pass
NOTIFICATIONS_DB_PASSWORD=notifications_local_pass

# JWT Secret (use a long random string — CHANGE THIS)
JWT_SECRET=local-jwt-secret-change-this-in-production-min-32-chars

# CORS: which origins can call the API
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:3000
